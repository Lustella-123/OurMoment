default_platform(:ios)

platform :ios do
  project_root = File.expand_path("../..", __dir__)

  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Increment iOS build number"
  lane :bump_build do
    increment_build_number(
      xcodeproj: "Runner.xcodeproj"
    )
  end

  desc "Build Flutter iOS IPA"
  lane :build_ios do
    Dir.chdir(project_root) do
      sh("flutter pub get")
      sh("flutter build ipa --release --export-method app-store")
    end
  end

  desc "Upload to TestFlight (ASC API key)"
  lane :upload_testflight do |options|
    bump_build if options[:bump] != false
    build_ios

    api_key = nil
    if ENV["APP_STORE_CONNECT_API_KEY_ID"] &&
       ENV["APP_STORE_CONNECT_API_ISSUER_ID"] &&
       ENV["APP_STORE_CONNECT_API_KEY_PATH"]
      api_key = app_store_connect_api_key(
        key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
        issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
        key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
      )
    end

    ipa_path = Dir[File.join(project_root, "build/ios/ipa/*.ipa")].max_by { |f| File.mtime(f) }
    UI.user_error!("Could not find IPA file. Check flutter build ipa logs.") unless ipa_path

    upload_to_testflight(
      ipa: ipa_path,
      api_key: api_key,
      skip_waiting_for_build_processing: options[:wait_processing] == true ? false : true,
      changelog: options[:changelog]
    )
  end
end
