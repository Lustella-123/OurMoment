rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function coupleDoc(coupleId) {
      return get(/databases/$(database)/documents/couples/$(coupleId));
    }

    // 트랜잭션 안에서 couples 먼저 갱신 후 users에 coupleId 쓸 때, get()은 아직 옛 문서를 봄 → getAfter() 필수
    function coupleAfter(coupleId) {
      return getAfter(/databases/$(database)/documents/couples/$(coupleId));
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function isCoupleMember(coupleId) {
      let c = coupleDoc(coupleId);
      return signedIn()
        && c.data != null
        && 'memberIds' in c.data
        && c.data.memberIds is list
        && request.auth.uid in c.data.memberIds;
    }

    function inviteCodeAfter(code) {
      return getAfter(/databases/$(database)/documents/inviteCodes/$(code));
    }

    // joiner의 coupleId 쓰기는 트랜잭션 밖 단일 update → 커플은 이미 커밋됨. get()/exists()가 맞고,
    // existsAfter/getAfter만 쓰면 “이번 요청에 안 건드린 문서” 평가에서 환경에 따라 거절되는 사례가 있음.
    function coupleIdUpdateAllowed() {
      let next = request.resource.data.get('coupleId', null);
      let prev = resource.data.get('coupleId', null);
      return next == prev
        || (next is string
          && exists(/databases/$(database)/documents/couples/$(next))
          && coupleDoc(next).data != null
          && coupleDoc(next).data.memberIds is list
          && request.auth.uid in coupleDoc(next).data.memberIds);
    }

    function inviteCodeUpdateAllowed() {
      let next = request.resource.data.get('inviteCode', null);
      let prev = resource.data.get('inviteCode', null);
      return prev == next
        || (prev == null && next is string && next.size() == 6);
    }

    // 같은 트랜잭션에서 couples set 직후 상대 users 갱신.
    // inviteCodes/{code}.claimedBy로 선점된 초대만 허용한다.
    function crossUserCoupleIdPairing(targetUid) {
      let cid = request.resource.data.get('coupleId', null);
      let nextCouple = coupleAfter(cid);
      let prevC = resource.data.get('coupleId', null);
      return signedIn()
        && request.auth.uid != targetUid
        && cid is string
        && existsAfter(/databases/$(database)/documents/couples/$(cid))
        && nextCouple.data != null
        && nextCouple.data.memberIds is list
        && request.auth.uid in nextCouple.data.memberIds
        && targetUid in nextCouple.data.memberIds
        && nextCouple.data.get('inviteCodeUsed', null) is string
        && existsAfter(
          /databases/$(database)/documents/inviteCodes/$(nextCouple.data.get('inviteCodeUsed', null))
        )
        && inviteCodeAfter(nextCouple.data.get('inviteCodeUsed', null)).data != null
        && inviteCodeAfter(nextCouple.data.get('inviteCodeUsed', null)).data.uid == targetUid
        && inviteCodeAfter(nextCouple.data.get('inviteCodeUsed', null)).data.get('claimedBy', null)
            == request.auth.uid
        && (prevC == null || prevC == cid);
    }

    // --- users: 본인만 쓰기. coupleId/inviteCode는 검증된 경우만 변경 ---
    match /users/{userId} {
      allow read: if isUser(userId)
        || (
          signedIn()
          && userDoc(request.auth.uid).data != null
          && userDoc(userId).data != null
          && userDoc(request.auth.uid).data.get('coupleId', null) is string
          && userDoc(request.auth.uid).data.get('coupleId', null)
            == userDoc(userId).data.get('coupleId', null)
        );
      allow create: if isUser(userId) && !('coupleId' in request.resource.data);
      allow update: if (isUser(userId)
          && coupleIdUpdateAllowed()
          && inviteCodeUpdateAllowed())
        || crossUserCoupleIdPairing(userId);
      allow delete: if false;
    }

    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn()
        && request.resource.data.uid == resource.data.uid
        && resource.data.get('claimedBy', null) == null
        && request.resource.data.get('claimedBy', null) == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'claimedBy', 'claimedAt']);
      allow delete: if false;
    }

    // 커플 문서는 멤버만 읽는다.
    match /couples/{coupleId} {
      allow read: if isCoupleMember(coupleId);
      // 초대코드 선점(claimedBy)된 2인 커플만 생성 허용.
      allow create: if signedIn()
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 2
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.get('inviteCodeUsed', null) is string
        && existsAfter(
          /databases/$(database)/documents/inviteCodes/$(request.resource.data.get('inviteCodeUsed', null))
        )
        && inviteCodeAfter(request.resource.data.get('inviteCodeUsed', null)).data != null
        && inviteCodeAfter(request.resource.data.get('inviteCodeUsed', null)).data.uid
            in request.resource.data.memberIds
        && inviteCodeAfter(request.resource.data.get('inviteCodeUsed', null)).data.uid
            != request.auth.uid
        && inviteCodeAfter(request.resource.data.get('inviteCodeUsed', null)).data.get('claimedBy', null)
            == request.auth.uid;
      // 멤버 변경은 불가. 기존 멤버만 메타데이터를 갱신.
      allow update: if signedIn()
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.get('createdAt', null) == resource.data.get('createdAt', null)
        && request.resource.data.get('inviteCodeUsed', null)
            == resource.data.get('inviteCodeUsed', null)
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() == 2
        && request.resource.data.memberIds == resource.data.memberIds;
      allow delete: if false;
    }

    function momentImageFieldsOk() {
      let d = request.resource.data;
      let urlOk = !('imageUrl' in d)
        || d.imageUrl == null
        || (d.imageUrl is string && d.imageUrl.size() <= 2048);
      let listOk = !('imageUrls' in d)
        || d.imageUrls == null
        || (d.imageUrls is list && d.imageUrls.size() <= 12);
      return urlOk && listOk;
    }

    // 순간(피드·일기 공통)
    match /couples/{coupleId}/moments/{momentId} {
      allow read: if isCoupleMember(coupleId);
      // hasAll(keys)는 SDK/필드 조합에 따라 누락으로 오탐될 수 있어 필드별로 검증
      allow create: if isCoupleMember(coupleId)
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.caption is string
        && request.resource.data.caption.size() <= 4000
        && request.resource.data.dayKey is string
        && request.resource.data.dayKey.size() == 10
        && request.resource.data.likeCount == 0
        && 'createdAt' in request.resource.data
        && momentImageFieldsOk();
      allow update: if isCoupleMember(coupleId)
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.dayKey == resource.data.dayKey
        && (
          (request.auth.uid == resource.data.authorUid
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['caption', 'imageUrl', 'imageUrls', 'updatedAt']))
          || (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['likeCount', 'updatedAt'])
            && request.resource.data.likeCount is int
            && request.resource.data.likeCount >= 0
            && request.resource.data.likeCount <= 2)
        );
      allow delete: if isCoupleMember(coupleId)
        && resource.data.authorUid == request.auth.uid;
    }

    match /couples/{coupleId}/moments/{momentId}/likes/{likerUid} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId)
        && request.auth.uid == likerUid
        && request.resource.data.keys().hasOnly(['createdAt']);
      allow update: if false;
      // 순간 삭제 시 상대 좋아요 문서 정리 등 — 커플 멤버만
      allow delete: if isCoupleMember(coupleId);
    }

    match /couples/{coupleId}/moments/{momentId}/comments/{commentId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId)
        && request.resource.data.keys().hasAll(['authorUid', 'text', 'createdAt'])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
      allow update: if isCoupleMember(coupleId)
        && resource.data.authorUid == request.auth.uid;
      allow delete: if isCoupleMember(coupleId)
        && resource.data.authorUid == request.auth.uid;
    }

    // 커플 공유 투두(메모)
    match /couples/{coupleId}/todos/{todoId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 1500
        && (!('itemType' in request.resource.data)
          || (request.resource.data.itemType in ['todo', 'memo']))
        && (!('category' in request.resource.data)
          || (request.resource.data.category is string
            && request.resource.data.category.size() <= 30))
        && (!('colorKey' in request.resource.data)
          || (request.resource.data.colorKey is string
            && request.resource.data.colorKey.size() <= 20))
        && request.resource.data.isDone is bool
        && request.resource.data.likeCount == 0
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll([
          'title',
          'note',
          'isDone',
          'likeCount',
          'createdBy',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isCoupleMember(coupleId)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 1500
        && (!('itemType' in request.resource.data)
          || (request.resource.data.itemType in ['todo', 'memo']))
        && (!('category' in request.resource.data)
          || (request.resource.data.category is string
            && request.resource.data.category.size() <= 30))
        && (!('colorKey' in request.resource.data)
          || (request.resource.data.colorKey is string
            && request.resource.data.colorKey.size() <= 20))
        && request.resource.data.isDone is bool
        && (
          !('likeCount' in request.resource.data)
          || (request.resource.data.likeCount is int
            && request.resource.data.likeCount >= 0)
        )
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isCoupleMember(coupleId);
    }

    match /couples/{coupleId}/todoCategories/{categoryId} {
      allow read: if isCoupleMember(coupleId);
      allow create, update: if isCoupleMember(coupleId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 30;
      allow delete: if isCoupleMember(coupleId);
    }

    match /couples/{coupleId}/todos/{todoId}/likes/{uid} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId)
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['createdAt']);
      allow update: if false;
      allow delete: if isCoupleMember(coupleId) && request.auth.uid == uid;
    }

    // 커플 공유 캘린더 일정
    match /couples/{coupleId}/calendarEvents/{eventId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isCoupleMember(coupleId)
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 500
        && request.resource.data.dayKey is string
        && request.resource.data.dayKey.size() == 10
        && request.resource.data.timeText is string
        && request.resource.data.timeText.size() <= 5
        && request.resource.data.colorKey is string
        && request.resource.data.colorKey.size() <= 20
        && request.resource.data.shapeKey is string
        && request.resource.data.shapeKey.size() <= 20
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasAll([
          'title',
          'note',
          'dayKey',
          'timeText',
          'colorKey',
          'shapeKey',
          'createdBy',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if isCoupleMember(coupleId)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 500
        && request.resource.data.dayKey is string
        && request.resource.data.dayKey.size() == 10
        && request.resource.data.timeText is string
        && request.resource.data.timeText.size() <= 5
        && request.resource.data.colorKey is string
        && request.resource.data.colorKey.size() <= 20
        && request.resource.data.shapeKey is string
        && request.resource.data.shapeKey.size() <= 20;
      allow delete: if isCoupleMember(coupleId);
    }

    // 구버전 일회성 초대 (미사용)
    match /invites/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.creatorUid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.creatorUid == request.auth.uid;
      allow delete: if false;
    }
  }
}
